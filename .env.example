# ============================================
# OrbitGuide - Konfiguracja środowiska
# ============================================
# Skopiuj ten plik jako .env i uzupełnij klucze API

# === Klucze API ===
# Google AI (wymagany dla embeddingów)
GOOGLE_API_KEY=your_google_api_key_here

# Groq (wymagany dla LLM)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (opcjonalnie)
OPENAI_API_KEY=your_openai_key_here

# === Modele ===
LLM_MODEL=llama-3.1-8b-instant
JUDGE_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=models/gemini-embedding-001

# === Parametry RAG ===
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
RETRIEVAL_K=5
TEMPERATURE=0
